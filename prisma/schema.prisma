generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
  moduleFormat    = "cjs"
}

datasource db {
  provider     = "postgresql"
  relationMode = "foreignKeys"
}

model Banca {
  id                         String                             @id @default(uuid()) @db.Uuid
  name                       String                             @unique
  code                       String                             @unique
  defaultMinBet              Float                              @default(100.00)
  globalMaxPerNumber         Int                                @default(5000)
  deletedAt                  DateTime?
  deletedBy                  String?
  deletedReason              String?
  createdAt                  DateTime                           @default(now())
  updatedAt                  DateTime                           @updatedAt
  address                    String?
  email                      String?
  phone                      String?
  isActive                   Boolean                            @default(true)
  salesCutoffMinutes         Int                                @default(1)
  commissionPolicyJson       Json?
  maxSessionsPerVendedor     Int                                @default(1)
  vendorLimit                Int?
  accountPayments            AccountPayment[]
  accountStatements          AccountStatement[]
  statementSettlementConfigs AccountStatementSettlementConfig[]
  activityLogs               ActivityLog[]
  alerts                     Alert[]
  apiKeys                    ApiKey[]
  loteriaSettings            BancaLoteriaSetting[]
  exportJobs                 ExportJob[]
  goals                      Goal[]
  jugadas                    Jugada[]
  loterias                   Loteria[]
  multipliers                LoteriaMultiplier[]
  monthlyClosingBalances     MonthlyClosingBalance[]            @relation("MonthlyClosingBalanceBanca")
  multiplierOverrides        MultiplierOverride[]
  refreshTokens              RefreshToken[]
  restrictionRules           RestrictionRule[]
  savedReports               SavedReport[]
  sorteos                    Sorteo[]
  sorteosAutoConfigs         SorteosAutoConfig[]
  tickets                    Ticket[]
  appUsers                   User[]
  users                      UserBanca[]
  ventanas                   Ventana[]
  webhooks                   Webhook[]
  sorteoListaExclusiones     SorteoListaExclusion[]
}

model Ventana {
  id                     String                  @id @default(uuid()) @db.Uuid
  bancaId                String                  @db.Uuid
  name                   String
  code                   String                  @unique
  commissionMarginX      Float
  deletedAt              DateTime?
  deletedBy              String?
  deletedReason          String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  address                String?
  email                  String?
  phone                  String?
  isActive               Boolean                 @default(true)
  commissionPolicyJson   Json?
  settings               Json?
  accountPayments        AccountPayment[]
  accountStatements      AccountStatement[]
  monthlyClosingBalances MonthlyClosingBalance[] @relation("MonthlyClosingBalanceVentana")
  multiplierOverrides    MultiplierOverride[]
  restrictionRules       RestrictionRule[]
  tickets                Ticket[]
  users                  User[]
  banca                  Banca                   @relation(fields: [bancaId], references: [id])
  sorteoListaExclusiones SorteoListaExclusion[]  @relation("ExclusionVentana")

  @@index([name])
  @@index([bancaId], map: "idx_ventana_bancaId_fk")
}

model User {
  id                                      String                             @id @default(uuid()) @db.Uuid
  ventanaId                               String?                            @db.Uuid
  name                                    String
  email                                   String?                            @unique
  phone                                   String?
  password                                String
  role                                    Role                               @default(VENTANA)
  deletedAt                               DateTime?
  deletedBy                               String?
  deletedReason                           String?
  createdAt                               DateTime                           @default(now())
  updatedAt                               DateTime                           @updatedAt
  isActive                                Boolean                            @default(true)
  username                                String                             @unique @db.Citext
  code                                    String?                            @unique
  commissionPolicyJson                    Json?
  settings                                Json?
  platform                                String?
  appVersion                              String?                            @db.VarChar(50)
  bancaId                                 String?                            @db.Uuid
  maxSessionsPerVendedor                  Int?
  accountPaymentsPaid                     AccountPayment[]                   @relation("AccountPaymentPaidBy")
  accountPaymentsReversed                 AccountPayment[]                   @relation("AccountPaymentReversedBy")
  accountPayments                         AccountPayment[]
  accountStatementsSettled                AccountStatement[]                 @relation("AccountStatementSettledBy")
  accountStatements                       AccountStatement[]
  accountStatementSettlementConfigUpdated AccountStatementSettlementConfig[] @relation("AccountStatementSettlementConfigUpdatedBy")
  activities                              ActivityLog[]
  alerts                                  Alert[]
  apiKeys                                 ApiKey[]
  exportJobs                              ExportJob[]
  jugadasExcluded                         Jugada[]                           @relation("JugadaExcludedBy")
  monthlyClosingBalances                  MonthlyClosingBalance[]            @relation("MonthlyClosingBalanceVendedor")
  multiplierOverrides                     MultiplierOverride[]
  refreshTokens                           RefreshToken[]
  restrictionRules                        RestrictionRule[]
  savedReports                            SavedReport[]
  sorteosAutoConfigUpdated                SorteosAutoConfig[]                @relation("SorteosAutoConfigUpdatedBy")
  ticketsCreated                          Ticket[]                           @relation("TicketCreatedBy")
  ticketsPaid                             Ticket[]                           @relation("TicketPaidBy")
  tickets                                 Ticket[]                           @relation("TicketVendedor")
  TicketPayment                           TicketPayment[]
  banca                                   Banca?                             @relation(fields: [bancaId], references: [id])
  ventana                                 Ventana?                           @relation(fields: [ventanaId], references: [id])
  bancas                                  UserBanca[]
  exclusionsCreated                       SorteoListaExclusion[]             @relation("ExclusionExcludedBy")
  exclusionsAsVendedor                    SorteoListaExclusion[]             @relation("ExclusionVendedor")

  @@index([email])
  @@index([name])
  @@index([username])
  @@index([bancaId])
  @@index([bancaId, role], map: "idx_user_banca_role")
  @@index([code(ops: raw("gin_trgm_ops"))], map: "idx_user_code_trgm", type: Gin)
  @@index([name(ops: raw("gin_trgm_ops"))], map: "idx_user_name_trgm", type: Gin)
  @@index([bancaId], map: "idx_user_banca_vendedor", where: raw("(role = 'VENDEDOR'::\"Role\")"))
  @@index([ventanaId, role, isActive], map: "idx_user_ventana_role_active", where: raw("((\"deletedAt\" IS NULL) AND (\"isActive\" = true))"))
}

model Loteria {
  id                  String                @id @default(uuid()) @db.Uuid
  name                String
  rulesJson           Json?
  deletedAt           DateTime?
  deletedBy           String?
  deletedReason       String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  isActive            Boolean               @default(true)
  bancaId             String?               @db.Uuid
  loteriaSettings     BancaLoteriaSetting[]
  banca               Banca?                @relation(fields: [bancaId], references: [id])
  multipliers         LoteriaMultiplier[]
  multiplierOverrides MultiplierOverride[]
  restrictionRules    RestrictionRule[]
  sorteos             Sorteo[]
  tickets             Ticket[]

  @@unique([name, bancaId])
  @@index([name])
  @@index([bancaId])
}

model BancaLoteriaSetting {
  id                String    @id @default(uuid()) @db.Uuid
  loteriaId         String    @db.Uuid
  baseMultiplierX   Float
  maxTotalPerSorteo Int?
  deletedAt         DateTime?
  deletedBy         String?
  deletedReason     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  bancaId           String?   @db.Uuid
  isActive          Boolean   @default(true)
  banca             Banca?    @relation(fields: [bancaId], references: [id])
  loteria           Loteria   @relation(fields: [loteriaId], references: [id])

  @@unique([bancaId, loteriaId])
  @@index([bancaId])
  @@index([loteriaId], map: "idx_bancaloteriasetting_loteriaId_fk")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Ticket {
  id              String          @id @default(uuid()) @db.Uuid
  ticketNumber    String          @unique @default(dbgenerated("generate_ticket_number()")) @db.VarChar(24)
  loteriaId       String          @db.Uuid
  ventanaId       String          @db.Uuid
  vendedorId      String          @db.Uuid
  totalAmount     Float
  status          TicketStatus    @default(ACTIVE)
  deletedAt       DateTime?
  deletedBy       String?
  deletedReason   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  isActive        Boolean         @default(true)
  isWinner        Boolean         @default(false)
  sorteoId        String          @db.Uuid
  totalPayout     Float?          @default(0)
  totalPaid       Float?          @default(0)
  remainingAmount Float?          @default(0)
  lastPaymentAt   DateTime?
  paidById        String?         @db.Uuid
  paymentMethod   String?
  paymentNotes    String?
  paymentHistory  Json?
  clienteNombre   String?         @default("CLIENTE CONTADO") @db.VarChar(100)
  businessDate    DateTime?       @db.Date
  totalCommission Float?          @default(0)
  createdBy       String?         @db.Uuid
  createdByRole   Role?
  isSorteoClosed  Boolean         @default(false)
  idempotencyKey  String?         @unique(where: raw("(\"idempotencyKey\" IS NOT NULL)"))
  bancaId         String?         @db.Uuid
  printCount      Int?            @default(0)
  jugadas         Jugada[]
  banca           Banca?          @relation(fields: [bancaId], references: [id])
  createdByUser   User?           @relation("TicketCreatedBy", fields: [createdBy], references: [id])
  loteria         Loteria         @relation(fields: [loteriaId], references: [id])
  paidBy          User?           @relation("TicketPaidBy", fields: [paidById], references: [id])
  sorteo          Sorteo          @relation(fields: [sorteoId], references: [id])
  vendedor        User            @relation("TicketVendedor", fields: [vendedorId], references: [id])
  ventana         Ventana         @relation(fields: [ventanaId], references: [id])
  TicketPayment   TicketPayment[]

  @@index([bancaId])
  @@index([vendedorId, sorteoId, deletedAt, isActive])
  @@index([ventanaId, businessDate, deletedAt])
  @@index([loteriaId], map: "idx_Ticket_loteriaId")
  @@index([businessDate, isActive, status, deletedAt, vendedorId, sorteoId, ventanaId], map: "idx_ticket_cierre_consolidado")
  @@index([bancaId, sorteoId], map: "idx_ticket_banca_sorteo_winner_perf", where: raw("((\"isActive\" = true) AND (\"isWinner\" = true) AND (\"deletedAt\" IS NULL))"))
  @@index([businessDate, sorteoId, isActive], map: "idx_ticket_business_date_sorteo", where: raw("(\"deletedAt\" IS NULL)"))
  @@index([businessDate, ventanaId, vendedorId], map: "idx_ticket_business_date_ventana_vendedor", where: raw("((\"deletedAt\" IS NULL) AND (status <> 'CANCELLED'::\"TicketStatus\"))"))
  @@index([createdAt], map: "idx_ticket_created_at", where: raw("((\"deletedAt\" IS NULL) AND (status <> 'CANCELLED'::\"TicketStatus\"))"))
  @@index([bancaId, businessDate, isActive, status], map: "idx_ticket_risk_banca_date", where: raw("(\"deletedAt\" IS NULL)"))
  @@index([sorteoId, status, isActive], map: "idx_ticket_sorteo_status", where: raw("(\"deletedAt\" IS NULL)"))
  @@index([isWinner, status, createdAt], map: "idx_ticket_winner_status_date", where: raw("((\"isActive\" = true) AND (\"deletedAt\" IS NULL))"))
  @@index([ventanaId, vendedorId, businessDate, status], map: "idx_tickets_ventana_vendedor_date", where: raw("((\"deletedAt\" IS NULL) AND (\"isActive\" = true) AND (status <> 'CANCELLED'::\"TicketStatus\"))"))
}

/// Contador global diario de tickets basado en businessDate (CR)
model TicketCounter {
  businessDate DateTime @id @unique(map: "idx_ticketcounter_date_unique") @db.Date
  last         Int      @default(0)
}

model TicketPayment {
  id              String    @id @default(uuid()) @db.Uuid
  ticketId        String    @db.Uuid
  amountPaid      Float
  paidById        String    @db.Uuid
  paymentDate     DateTime  @default(now())
  method          String?
  notes           String?
  isReversed      Boolean   @default(false)
  reversedAt      DateTime?
  reversedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  idempotencyKey  String?   @unique
  isPartial       Boolean   @default(false)
  remainingAmount Float?
  isFinal         Boolean   @default(false)
  completedAt     DateTime?
  paidBy          User      @relation(fields: [paidById], references: [id])
  ticket          Ticket    @relation(fields: [ticketId], references: [id])

  @@index([ticketId, isReversed])
  @@index([ticketId, createdAt])
  @@index([paidById], map: "idx_ticketpayment_paidById_fk")
}

model Jugada {
  id                      String             @id @default(uuid()) @db.Uuid
  ticketId                String             @db.Uuid
  number                  String
  amount                  Float
  finalMultiplierX        Float
  payout                  Float?
  isActive                Boolean            @default(true)
  deletedAt               DateTime?
  deletedBy               String?
  deletedReason           String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  isWinner                Boolean            @default(false)
  multiplierId            String?            @db.Uuid
  reventadoNumber         String?
  type                    BetType            @default(NUMERO)
  commissionPercent       Float              @default(0)
  commissionAmount        Float              @default(0)
  commissionOrigin        String?
  commissionRuleId        String?
  listeroCommissionAmount Float              @default(0)
  isExcluded              Boolean            @default(false)
  excludedAt              DateTime?
  excludedBy              String?            @db.Uuid
  excludedReason          String?
  bancaId                 String?            @db.Uuid
  banca                   Banca?             @relation(fields: [bancaId], references: [id])
  excludedByUser          User?              @relation("JugadaExcludedBy", fields: [excludedBy], references: [id])
  multiplier              LoteriaMultiplier? @relation("JugadaMultiplierAtSale", fields: [multiplierId], references: [id])
  ticket                  Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([reventadoNumber])
  @@index([multiplierId, isExcluded])
  @@index([ticketId, multiplierId], map: "idx_jugada_exclusiones_lookup", where: raw("((\"deletedAt\" IS NULL) AND (\"isActive\" = true))"))
  @@index([ticketId, number, type, isActive, isExcluded, amount, payout, listeroCommissionAmount, finalMultiplierX], map: "idx_jugada_maestro_final", where: raw("(\"deletedAt\" IS NULL)"))
  @@index([number, ticketId, amount, type], map: "idx_jugada_number_amount_active", where: raw("((\"deletedAt\" IS NULL) AND (\"isActive\" = true))"))
  @@index([ticketId, deletedAt, commissionOrigin], map: "idx_jugada_ticket_deleted_commission", where: raw("(\"deletedAt\" IS NULL)"))
  @@index([ticketId, isWinner, deletedAt, payout], map: "idx_jugada_ticket_winner", where: raw("((\"deletedAt\" IS NULL) AND (\"isWinner\" = true))"))
}

model Sorteo {
  id                   String                 @id @default(uuid()) @db.Uuid
  loteriaId            String                 @db.Uuid
  scheduledAt          DateTime
  status               SorteoStatus           @default(SCHEDULED)
  winningNumber        String?
  isActive             Boolean                @default(true)
  deletedAt            DateTime?
  deletedBy            String?
  deletedReason        String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  name                 String
  extraMultiplierId    String?                @db.Uuid
  extraMultiplierX     Float?
  extraOutcomeCode     String?
  hasWinner            Boolean                @default(false)
  deletedByCascadeFrom String?
  deletedByCascadeId   String?                @db.Uuid
  deletedByCascade     Boolean                @default(false)
  digits               Int                    @default(2)
  bancaId              String?                @db.Uuid
  banca                Banca?                 @relation(fields: [bancaId], references: [id])
  extraMultiplier      LoteriaMultiplier?     @relation("SorteoExtraMultiplier", fields: [extraMultiplierId], references: [id])
  loteria              Loteria                @relation(fields: [loteriaId], references: [id])
  tickets              Ticket[]
  exclusions           SorteoListaExclusion[]

  @@unique([loteriaId, scheduledAt, bancaId])
  @@index([loteriaId, deletedAt], map: "idx_sorteos_loteria_id_deleted_at")
  @@index([bancaId])
  @@index([extraMultiplierId])
  @@index([name])
  @@index([winningNumber])
  @@index([name(ops: raw("gin_trgm_ops"))], map: "idx_sorteo_name_trgm", type: Gin)
  @@index([id], map: "idx_sorteo_status_open", where: raw("(status = 'OPEN'::\"SorteoStatus\")"))
  @@index([status, scheduledAt, loteriaId], map: "idx_sorteo_status_scheduled", where: raw("(\"deletedAt\" IS NULL)"))
}

model SorteoListaExclusion {
  id             String             @id @default(uuid()) @db.Uuid
  sorteoId       String             @map("sorteo_id") @db.Uuid
  ventanaId      String             @map("ventana_id") @db.Uuid
  vendedorId     String?            @map("vendedor_id") @db.Uuid
  excludedAt     DateTime           @default(now()) @map("excluded_at")
  excludedBy     String             @map("excluded_by") @db.Uuid
  reason         String?
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  multiplierId   String?            @map("multiplier_id") @db.Uuid
  bancaId        String?            @map("banca_id") @db.Uuid
  banca          Banca?             @relation(fields: [bancaId], references: [id])
  excludedByUser User               @relation("ExclusionExcludedBy", fields: [excludedBy], references: [id])
  multiplier     LoteriaMultiplier? @relation("ExclusionMultiplier", fields: [multiplierId], references: [id])
  sorteo         Sorteo             @relation(fields: [sorteoId], references: [id], onDelete: Cascade)
  vendedor       User?              @relation("ExclusionVendedor", fields: [vendedorId], references: [id])
  ventana        Ventana            @relation("ExclusionVentana", fields: [ventanaId], references: [id])

  @@unique([sorteoId, ventanaId, vendedorId, multiplierId], map: "sorteo_lista_exclusion_sorteo_ventana_vendedor_multiplier_key")
  @@index([sorteoId])
  @@index([ventanaId])
  @@index([vendedorId])
  @@index([bancaId])
  @@index([multiplierId])
  @@index([excludedBy], map: "idx_sorteo_lista_exclusion_exBy_fk")
  @@index([sorteoId, ventanaId, vendedorId], map: "idx_sorteo_exclusion_lookup", where: raw("(multiplier_id IS NULL)"))
  @@map("sorteo_lista_exclusion")
}

model ActivityLog {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String?      @db.Uuid
  action     ActivityType
  targetType String?
  targetId   String?
  details    Json?
  createdAt  DateTime     @default(now())
  bancaId    String?      @db.Uuid
  banca      Banca?       @relation(fields: [bancaId], references: [id])
  user       User?        @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([bancaId])
  @@index([targetType])
  @@index([bancaId, targetType, createdAt(sort: Desc)], map: "idx_activity_log_target_date")
  @@index([userId], map: "idx_activity_log_user_id")
}

model RestrictionRule {
  id                 String             @id @default(uuid()) @db.Uuid
  ventanaId          String?            @db.Uuid
  userId             String?            @db.Uuid
  number             String?
  maxAmount          Float?
  maxTotal           Float?
  appliesToDate      DateTime?
  appliesToHour      Int?
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  salesCutoffMinutes Int?
  loteriaId          String?            @db.Uuid
  multiplierId       String?            @db.Uuid
  message            String?            @db.VarChar(255)
  isAutoDate         Boolean            @default(false)
  baseAmount         Float?
  salesPercentage    Float?
  appliesToVendedor  Boolean            @default(false)
  bancaId            String?            @db.Uuid
  banca              Banca?             @relation(fields: [bancaId], references: [id])
  loteria            Loteria?           @relation(fields: [loteriaId], references: [id])
  multiplier         LoteriaMultiplier? @relation(fields: [multiplierId], references: [id])
  user               User?              @relation(fields: [userId], references: [id])
  ventana            Ventana?           @relation(fields: [ventanaId], references: [id])

  @@index([loteriaId])
  @@index([multiplierId])
  @@index([bancaId])
  @@index([number, isActive, loteriaId], map: "idx_restriction_number_active", where: raw("((\"isActive\" = true) AND (number IS NOT NULL))"))
  @@index([isAutoDate, isActive], map: "idx_restriction_rule_auto_date_active", where: raw("((\"isAutoDate\" = true) AND (\"isActive\" = true))"))
  @@index([salesPercentage], map: "idx_restriction_rules_sales_percentage", where: raw("(\"salesPercentage\" IS NOT NULL)"))
  @@index([userId], map: "idx_restrictionrule_userId_fk")
  @@index([ventanaId], map: "idx_restrictionrule_ventanaId_fk")
}

model LoteriaMultiplier {
  id                    String                 @id @default(uuid()) @db.Uuid
  loteriaId             String                 @db.Uuid
  name                  String
  valueX                Float
  isActive              Boolean                @default(true)
  appliesToDate         DateTime?
  appliesToSorteoId     String?                @db.Uuid
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  kind                  MultiplierKind         @default(NUMERO)
  bancaId               String?                @db.Uuid
  jugadasAtSale         Jugada[]               @relation("JugadaMultiplierAtSale")
  banca                 Banca?                 @relation(fields: [bancaId], references: [id])
  loteria               Loteria                @relation(fields: [loteriaId], references: [id])
  restrictionRules      RestrictionRule[]
  appliedInSorteos      Sorteo[]               @relation("SorteoExtraMultiplier")
  sorteoListaExclusions SorteoListaExclusion[] @relation("ExclusionMultiplier")

  @@index([loteriaId, kind, isActive])
  @@index([bancaId])
  @@index([appliesToSorteoId])
}

model MultiplierOverride {
  id              String        @id @default(uuid()) @db.Uuid
  scope           OverrideScope
  userId          String?       @db.Uuid
  ventanaId       String?       @db.Uuid
  loteriaId       String        @db.Uuid
  multiplierType  String
  baseMultiplierX Float
  isActive        Boolean       @default(true)
  deletedAt       DateTime?
  deletedBy       String?
  deletedReason   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  bancaId         String?       @db.Uuid
  banca           Banca?        @relation(fields: [bancaId], references: [id])
  loteria         Loteria       @relation(fields: [loteriaId], references: [id])
  user            User?         @relation(fields: [userId], references: [id])
  ventana         Ventana?      @relation(fields: [ventanaId], references: [id])

  @@unique([scope, userId, ventanaId, loteriaId, multiplierType], map: "uniq_override_scope_target")
  @@index([scope, userId, ventanaId, loteriaId, multiplierType], map: "idx_override_lookup")
  @@index([bancaId])
  @@index([loteriaId], map: "idx_multiplieroverride_loteriaId_fk")
  @@index([userId], map: "idx_multiplieroverride_userId_fk")
  @@index([ventanaId], map: "idx_multiplieroverride_ventanaId_fk")
}

model RefreshToken {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  token         String    @unique
  revoked       Boolean   @default(false)
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deviceId      String?   @db.VarChar(255)
  deviceName    String?   @db.VarChar(255)
  userAgent     String?
  ipAddress     String?   @db.VarChar(45)
  lastUsedAt    DateTime? @default(now())
  revokedAt     DateTime?
  revokedReason String?   @db.VarChar(50)
  bancaId       String?   @db.Uuid
  banca         Banca?    @relation(fields: [bancaId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_token_user_id")
  @@index([bancaId, revoked, expiresAt], map: "idx_refreshtoken_pool_count")
  @@index([userId, deviceId], map: "idx_refresh_token_user_device", where: raw("(\"deviceId\" IS NOT NULL)"))
}

model UserBanca {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  bancaId   String   @db.Uuid
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  banca     Banca    @relation(fields: [bancaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bancaId], map: "UserBanca_userId_bancaId_unique")
  @@index([userId])
  @@index([bancaId])
  @@index([userId, isDefault], map: "UserBanca_isDefault_idx", where: raw("(\"isDefault\" = true)"))
  @@map("UserBanca")
}

