model AccountStatement {
  id                 String           @id @default(uuid()) @db.Uuid
  date               DateTime         @db.Date
  month              String           @db.VarChar(7)
  ventanaId          String?          @db.Uuid
  vendedorId         String?          @db.Uuid
  totalSales         Float            @default(0)
  totalPayouts       Float            @default(0)
  listeroCommission  Float            @default(0)
  vendedorCommission Float            @default(0)
  balance            Float            @default(0)
  totalPaid          Float            @default(0)
  remainingBalance   Float            @default(0)
  isSettled          Boolean          @default(false)
  canEdit            Boolean          @default(true)
  ticketCount        Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  totalCollected     Float            @default(0)
  settledAt          DateTime?
  settledBy          String?          @db.Uuid
  accumulatedBalance Float            @default(0)
  bancaId            String?          @db.Uuid
  payments           AccountPayment[]
  banca              Banca?           @relation(fields: [bancaId], references: [id], onDelete: Cascade)
  settledByUser      User?            @relation("AccountStatementSettledBy", fields: [settledBy], references: [id])
  vendedor           User?            @relation(fields: [vendedorId], references: [id], onDelete: Cascade)
  ventana            Ventana?         @relation(fields: [ventanaId], references: [id], onDelete: Cascade)

  @@unique([date, vendedorId], map: "account_statements_date_vendedor_unique")
  @@unique([date, ventanaId], map: "account_statements_date_ventana_unique", where: raw("((\"ventanaId\" IS NOT NULL) AND (\"vendedorId\" IS NULL))"))
  @@index([month])
  @@index([date])
  @@index([bancaId])
  @@index([isSettled])
  @@index([isSettled, date])
  @@index([month, isSettled, date])
  @@index([vendedorId, date])
  @@index([vendedorId, date, remainingBalance], map: "idx_account_statement_vendedor_covering_v3")
  @@index([vendedorId], where: raw("(\"vendedorId\" IS NOT NULL)"))
  @@index([ventanaId], where: raw("(\"ventanaId\" IS NOT NULL)"))
  @@index([date, remainingBalance], map: "idx_account_statement_banca_sum_v3", where: raw("((\"vendedorId\" IS NULL) AND (\"ventanaId\" IS NULL))"))
  @@index([month, isSettled], map: "idx_account_statements_month_settled", where: raw("(\"isSettled\" = true)"))
  @@index([settledBy], map: "idx_accountstatement_settledBy_fk")
  @@index([bancaId, date(sort: Desc)], map: "idx_as_banca_date", where: raw("((\"ventanaId\" IS NULL) AND (\"vendedorId\" IS NULL))"))
  @@index([vendedorId, date(sort: Desc)], map: "idx_as_vendedor_date", where: raw("(\"vendedorId\" IS NOT NULL)"))
  @@index([ventanaId, date(sort: Desc)], map: "idx_as_ventana_date", where: raw("((\"ventanaId\" IS NOT NULL) AND (\"vendedorId\" IS NULL))"))
}

model AccountPayment {
  id                 String           @id @default(uuid()) @db.Uuid
  accountStatementId String           @db.Uuid
  date               DateTime         @db.Date
  month              String           @db.VarChar(7)
  ventanaId          String?          @db.Uuid
  vendedorId         String?          @db.Uuid
  amount             Float
  type               String           @db.VarChar(20)
  method             String           @db.VarChar(20)
  notes              String?
  isFinal            Boolean          @default(false)
  isReversed         Boolean          @default(false)
  reversedAt         DateTime?
  reversedBy         String?          @db.Uuid
  paidById           String           @db.Uuid
  paidByName         String           @db.VarChar(255)
  idempotencyKey     String?          @unique
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  time               String?          @db.VarChar(5)
  bancaId            String?          @db.Uuid
  accountStatement   AccountStatement @relation(fields: [accountStatementId], references: [id])
  banca              Banca?           @relation(fields: [bancaId], references: [id], onDelete: Cascade)
  paidBy             User             @relation("AccountPaymentPaidBy", fields: [paidById], references: [id])
  reversedByUser     User?            @relation("AccountPaymentReversedBy", fields: [reversedBy], references: [id])
  vendedor           User?            @relation(fields: [vendedorId], references: [id], onDelete: Cascade)
  ventana            Ventana?         @relation(fields: [ventanaId], references: [id], onDelete: Cascade)

  @@index([accountStatementId])
  @@index([date])
  @@index([month])
  @@index([bancaId])
  @@index([isReversed])
  @@index([paidById], map: "idx_AccountPayment_paidById")
  @@index([reversedBy], map: "idx_AccountPayment_reversedBy")
  @@index([vendedorId], where: raw("(\"vendedorId\" IS NOT NULL)"))
  @@index([ventanaId], where: raw("(\"ventanaId\" IS NOT NULL)"))
  @@index([date, vendedorId], map: "idx_account_payment_date_vendedor", where: raw("((\"isReversed\" = false) AND (\"vendedorId\" IS NOT NULL))"))
  @@index([date, ventanaId], map: "idx_account_payment_date_ventana", where: raw("(\"isReversed\" = false)"))
  @@index([accountStatementId, isReversed, type], map: "idx_account_payment_statement_reversed_type", where: raw("(\"isReversed\" = false)"))
}

