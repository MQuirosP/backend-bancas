# ═══════════════════════════════════════════════════════════
# SERVIDOR
# ═══════════════════════════════════════════════════════════
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DISABLE_AUTH=false

# ═══════════════════════════════════════════════════════════
# BASE DE DATOS
# Descomenta SOLO el bloque que quieras usar.
# ═══════════════════════════════════════════════════════════

# ── LOCAL ────────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:password@localhost:5432/bancas_dev
# DIRECT_URL=postgresql://postgres:password@localhost:5432/bancas_dev
# DATABASE_URL_REPLICA=postgresql://postgres:password@localhost:5432/bancas_dev

# ── SUPABASE (Producción) ─────────────────────────────────
#   DATABASE_URL  → Transaction Pooler (puerto 6543) — para requests web
#   DIRECT_URL    → Session Pooler (puerto 5432) — para migraciones/jobs
#   DATABASE_URL_REPLICA → Réplica de lectura (solo lectura: reportes, dashboard)
SUPABASE_KEY=
# DATABASE_URL=postgresql://postgres.PROJECT_REF:password@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=8&pool_timeout=5&statement_timeout=20000&sslmode=require
# DIRECT_URL=postgresql://postgres.PROJECT_REF:password@aws-REGION.pooler.supabase.com:5432/postgres?connection_limit=3
# DATABASE_URL_REPLICA=postgresql://postgres.PROJECT_REF-rr-REGION:password@aws-REGION.pooler.supabase.com:5432/postgres?connection_limit=5&pool_timeout=30

# ── NEON (branch: production) ─────────────────────────────
# DATABASE_URL=postgresql://neondb_owner:password@ep-NAME-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true
# DIRECT_URL=postgresql://neondb_owner:password@ep-NAME.REGION.aws.neon.tech/neondb?sslmode=require
# DATABASE_URL_REPLICA=postgresql://neondb_owner:password@ep-NAME-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# ═══════════════════════════════════════════════════════════
# AUTENTICACIÓN (JWT)
# ═══════════════════════════════════════════════════════════
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=60m
JWT_REFRESH_EXPIRES_IN=7d

# ═══════════════════════════════════════════════════════════
# CORS
# ═══════════════════════════════════════════════════════════
CORS_ORIGIN=

# ═══════════════════════════════════════════════════════════
# REGLAS DE NEGOCIO
# ═══════════════════════════════════════════════════════════
# Zona horaria del negocio (IANA timezone name).
# Afecta: creación de sorteos, rangos de fechas, reportes, cron jobs.
# Default si no se declara: America/Costa_Rica (UTC-6, sin DST)
# Otros ejemplos: Europe/Madrid, America/New_York, America/Panama
BUSINESS_TIMEZONE=America/Costa_Rica
SALES_DAILY_MAX=100000
MULTIPLIER_BASE_DEFAULT_X=90

# ═══════════════════════════════════════════════════════════
# TRANSACCIONES
# ═══════════════════════════════════════════════════════════
TX_MAX_RETRIES=3
TX_BACKOFF_MIN_MS=250
TX_BACKOFF_MAX_MS=600

# ═══════════════════════════════════════════════════════════
# REDIS / CACHE
# ═══════════════════════════════════════════════════════════
CACHE_ENABLED=true
# true  → 503 si Redis cae (Producción)
# false → Bypass sin error (QA/Desarrollo)
IDEMPOTENCY_STRICT_MODE=true
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=
CACHE_TTL_CUTOFF=300
CACHE_TTL_RESTRICTIONS=300

# ═══════════════════════════════════════════════════════════
# APK AUTO-UPDATE
# ═══════════════════════════════════════════════════════════
API_BASE_URL=http://localhost:3000
APP_VERSION=2.0.0
APP_VERSION_CODE=3
APP_BUILD_NUMBER=20251211001
APP_CHANGELOG=Correcciones visuales y mejoras de rendimiento
APP_RELEASED_AT=2025-12-11T20:00:00Z
APP_MIN_SUPPORTED_VERSION=2.0.0
APP_FORCE_UPDATE=false

# ═══════════════════════════════════════════════════════════
# MONITOREO (Sentry)
# ═══════════════════════════════════════════════════════════
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ═══════════════════════════════════════════════════════════
# HARDENING & EVENT LOOP
# ═══════════════════════════════════════════════════════════
MAX_CONCURRENT_REQUESTS=25
EVENT_LOOP_LAG_THRESHOLD_MS=300
REQUEST_TIMEOUT_MS=15000
PRISMA_CB_RESET_MS=15000
REDIS_CB_RESET_MS=10000